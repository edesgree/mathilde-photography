---
interface Photo {
  src: string;
  thumb: string;
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<!-- ── Thumbnail grid ── -->
<div class="swiper gallery-thumbs">
  <div class="swiper-wrapper">
    {photos.map((photo, i) => (
      <div
        class="swiper-slide gallery-thumbs__slide"
        role="button"
        tabindex="0"
        aria-label={`View photo: ${photo.alt}`}
      >
        <img
          src={photo.thumb}
          alt={photo.alt}
          loading={i < 9 ? 'eager' : 'lazy'}
          decoding="async"
          width={photo.width}
          height={photo.height}
        />
      </div>
    ))}
  </div>
</div>

<!-- ── Lightbox overlay ── -->
<div class="gallery-lightbox-wrap" role="dialog" aria-modal="true" aria-label="Photo lightbox">
  <button class="gallery-lightbox-close" aria-label="Close lightbox">✕</button>

  <div class="swiper gallery-lightbox">
    <div class="swiper-wrapper">
      {photos.map((photo) => (
        <div class="swiper-slide">
          <div class="swiper-zoom-container">
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      ))}
    </div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>

  <div class="gallery-lightbox-counter" id="lb-counter"></div>
</div>

<script>
  import { initGallerySwiper } from '../scripts/swiper';
  initGallerySwiper();
</script>

<style lang="scss">
@use '../styles/variables' as *;
@use '../styles/mixins' as *;

// ── Thumbnail grid ──────────────────────────
.gallery-thumbs {
  // Lay out as a CSS grid — Swiper handles the DOM
  // but we override its flex with grid-like sizing
  &.swiper {
    width: 100%;
    // Let slides define their own size via slidesPerView: 'auto'
  }

  .swiper-wrapper {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    // grid overrides swiper flex — no actual sliding on the grid
    transform: none !important;
    flex-wrap: wrap;

    @include desktop { grid-template-columns: repeat(2, 1fr); }
    @include mobile  { grid-template-columns: 1fr; }
  }

  &__slide {
    // Override Swiper's width:auto — grid handles sizing
    width: auto !important;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: $surface;
    cursor: pointer;
    position: relative;

    @include focus-ring;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s $ease-out-expo, opacity 0.3s;
      opacity: 0.88;
      display: block;
    }

    &::after {
      content: '';
      @include full-overlay(rgba(0,0,0,0.25));
      opacity: 0;
      transition: opacity 0.3s;
    }

    &:hover {
      img {
        transform: scale(1.04);
        opacity: 1;
      }
      &::after { opacity: 1; }
    }
  }
}

// ── Lightbox overlay ────────────────────────
.gallery-lightbox-wrap {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(8, 8, 8, 0.97);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;

  &.is-open {
    opacity: 1;
    pointer-events: auto;
  }
}

.gallery-lightbox-close {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  z-index: 10;
  background: none;
  border: none;
  color: $white;
  font-size: 20px;
  cursor: pointer;
  padding: 0.5rem;
  line-height: 1;
  transition: color 0.2s;

  &:hover { color: $accent; }
}

.gallery-lightbox {
  width: 100%;
  height: 100%;

  .swiper-slide {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .swiper-zoom-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;

    img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
      user-select: none;
    }
  }

  // Navigation arrows
  :global(.swiper-button-prev),
  :global(.swiper-button-next) {
    color: rgba($white, 0.6);
    transition: color 0.2s;

    &:hover { color: $accent; }
    &::after { font-size: 20px; }

    @include mobile {
      &::after { font-size: 14px; }
    }
  }
}

.gallery-lightbox-counter {
  position: absolute;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  font-size: 11px;
  letter-spacing: 0.15em;
  color: rgba($white, 0.5);
  z-index: 10;
  pointer-events: none;
}
</style>
