---
import BaseLayout from '../layouts/BaseLayout.astro';
import { heroSlides as slides, categories } from '../data/photos';
---

<BaseLayout>

  <!-- ── Hero ── -->
  <section class="hero" aria-label="Hero slideshow">

    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        {slides.map((slide, i) => (
          <div class="swiper-slide">
            <img
              src={slide.src}
              alt={slide.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>

    <div class="hero__overlay"></div>

    <!-- <div class="hero__content container">
      <p class="eyebrow">Photography · Video</p>
      <h1 class="hero__title display">Mathilde<br />Godard</h1>
      <p class="hero__sub">Nantes, France</p>
    </div> -->

    <a href="/portfolio" class="hero__scroll" aria-label="View portfolio">
      <span class="eyebrow">Portfolio</span>
      <span class="hero__scroll-line"></span>
    </a>

  </section>

  <!-- ── Categories ── -->
  <section class="categories container">
    <h2 class="categories__heading display">Photography</h2>
    <div class="categories__grid">
      {categories.map(cat => (
        <a href={cat.href} class="cat-card">
          <div class="cat-card__img">
            <img src={cat.src} alt={cat.label} loading="lazy" />
          </div>
          <div class="cat-card__label">
            <span class="eyebrow">{cat.label}</span>
          </div> 
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  import { initHeroSwiper } from '../scripts/swiper';
  initHeroSwiper();
</script>

<style lang="scss">
@use '../styles/variables' as *;
@use '../styles/mixins' as *;

// ── Hero ──
.hero {
  position: relative;
  height: 100svh;
  min-height: 600px;
  overflow: hidden;
}

.hero-swiper {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;

  .swiper-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.swiper-pagination) {
    bottom: 2rem;
  }

  :global(.swiper-pagination-bullet) {
    width: 24px;
    height: 2px;
    border-radius: 0;
    background: rgba($white, 0.35);
    opacity: 1;
    transition: width 0.3s, background 0.3s;
    margin: 0 4px !important;
  }

  :global(.swiper-pagination-bullet-active) {
    width: 48px;
    background: $white;
  }

  :global(.swiper-button-prev),
  :global(.swiper-button-next) {
    color: rgba($white, 0.6);
    transition: color 0.2s;
    &:hover { color: $accent; }
    &::after { font-size: 20px; }
  }
}

.hero__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.1) 0%,
    rgba(0,0,0,0.0) 40%,
    rgba(0,0,0,0.55) 100%
  );
}

.hero__content {
  position: absolute;
  bottom: 12%;
  left: 0; right: 0;
  z-index: 10;
  pointer-events: none;
}

.hero__title {
  font-size: clamp(56px, 12vw, 140px);
  color: $white;
  margin: 0.3rem 0 0.5rem;
  text-shadow: 0 2px 40px rgba(0,0,0,0.3);
}

.hero__sub {
  font-size: 13px;
  letter-spacing: 0.2em;
  color: rgba($white, 0.6);
  text-transform: uppercase;
}

.hero__scroll {
  position: absolute;
  right: 2rem;
  bottom: 2rem;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: rgba($white, 0.6);
  transition: color 0.2s;
  &:hover { color: $accent; }
}

.hero__scroll-line {
  display: block;
  width: 1px;
  height: 48px;
  background: currentColor;
  animation: scrollLine 1.8s ease-in-out infinite;
}

@keyframes scrollLine {
  0%   { transform: scaleY(0); transform-origin: top;    opacity: 0; }
  40%  { transform: scaleY(1); transform-origin: top;    opacity: 1; }
  60%  { transform: scaleY(1); transform-origin: bottom; opacity: 1; }
  100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
}

// ── Categories ──
.categories {
  padding-top: 8rem;

  &__heading {
    font-size: clamp(36px, 6vw, 72px);
    margin-bottom: 3rem;
    color: $white;
  }

  &__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 3px;

    @include desktop { grid-template-columns: repeat(2, 1fr); }
    @include mobile  { grid-template-columns: 1fr; }
  }
}

.cat-card {
  position: relative;
  display: block;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: $surface;

  &__img {
    position: absolute;
    inset: 0;

    img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.7s $ease-out-expo;
      filter: brightness(0.75);
    }
  }

  &:hover &__img img {
    transform: scale(1.06);
    filter: brightness(0.55);
  }

  &__label {
    position: absolute;
    bottom: 1.2rem;
    left: 0; right: 0;
    text-align: center;
    color: $white;
    transition: color 0.2s;
  }

  &:hover &__label { color: $accent; }
}
</style>
