---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { videos } from '../../data/videos';

export function getStaticPaths() {
  return videos.map(v => ({
    params: { slug: v.slug },
    props: { video: v },
  }));
}

const { video } = Astro.props;

---

<BaseLayout title={video.title} description={video.description.slice(0, 150)}>
  <div class="video-detail">

    <div class="video-detail__header container">
      <a href="/videos" class="video-detail__back eyebrow">← Videos</a>
      <p class="eyebrow">{video.category} · {video.year}</p>
      <h1 class="video-detail__title display">{video.title}</h1>
    </div>

    <div class="video-detail__player container">
      <div class="video-detail__embed">
        <iframe
          src={video.embedUrl}
          title={video.title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>

    <div class="video-detail__body container">
      <div class="video-detail__description">
        {video.description.split('\n').filter(p => p.trim()).map(p => (
          <p>{p.trim()}</p>
        ))}
      </div>

      {video.credits && (
        <div class="video-detail__credits">
          <span class="eyebrow">Credits</span>
          <ul>
            {video.credits.map(c => (
              <li>
                <span class="credit-role">{c.role}</span>
                <span class="credit-name">{c.name}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

  </div>
</BaseLayout>

<style lang="scss">
@use '../../styles/variables' as *;
@use '../../styles/mixins' as *;

.video-detail {
  padding-top: calc(#{$nav-height} + 4rem);

  &__header {
    padding-bottom: 2rem;
    border-bottom: 1px solid $border;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  &__back {
    color: $muted;
    transition: color 0.2s;
    margin-bottom: 0.5rem;
    &:hover { color: $accent; }
  }

  &__title {
    font-size: clamp(40px, 8vw, 96px);
    color: $white;
    margin-top: 0.25rem;
  }

  &__player {
    padding-top: 3rem;
  }

  &__embed {
    position: relative;
    aspect-ratio: 16/9;
    background: $surface;

    iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
  }

  &__body {
    padding-top: 3rem;
    padding-bottom: 6rem;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;

    @include tablet {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  &__description {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;

    p {
      color: rgba($text, 0.75);
      font-size: 16px;
      line-height: 1.8;
      max-width: 65ch;
    }
  }

  &__credits {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.5rem;

    ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      border-top: 1px solid $border;
      padding-top: 1rem;
    }

    li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      font-size: 13px;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid rgba($border, 0.5);
    }

    .credit-role { color: $muted; }
    .credit-name { color: $text; text-align: right; }
  }
}
</style>