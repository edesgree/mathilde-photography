---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { videos } from '../../data/videos';
---

<BaseLayout
  title="Video Director"
  description="Mathilde Godard — réalisatrice et post-productrice vidéo à Nantes."
>
  <div class="videos-page">
    <div class="videos-page__header container">
      <p class="eyebrow">Direction & Post-production</p>
      <h1 class="videos-page__title display">Video</h1>
    </div>

    <div class="videos-list container">
      {videos.map((video, i) => (
        <article class="video-item">
          <div class="video-item__embed">
            <iframe
              src={video.embedUrl}
              title={video.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading={i === 0 ? 'eager' : 'lazy'}
            ></iframe>
          </div>
          <div class="video-item__info">
            <span class="eyebrow">{video.year}</span>
            <h2 class="video-item__title display">{video.title}</h2>
            <a class="video-item__desc" href={`/videos/${video.slug}`}>
              View project details
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style lang="scss">
.videos-page { padding-top: calc(var(--nav-height) + 4rem); }
.videos-page__header {
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--c-border);
}
.videos-page__title {
  font-size: clamp(48px, 10vw, 110px);
  color: var(--c-white);
  margin-top: 0.5rem;
}

.videos-list {
  padding-top: 4rem;
  display: flex;
  flex-direction: column;
  gap: 6rem;
}

.video-item {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.video-item:nth-child(even) { direction: rtl; }
.video-item:nth-child(even) > * { direction: ltr; }

.video-item__embed {
  position: relative;
  aspect-ratio: 16/9;
  background: var(--c-surface);
  overflow: hidden;
}
.video-item__embed iframe {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  border: none;
}

.video-item__info { display: flex; flex-direction: column; gap: 0.75rem; }
.video-item__title {
  font-size: clamp(28px, 4vw, 52px);
  color: var(--c-white);
  margin-top: 0.25rem;
}
.video-item__desc { color: var(--c-muted); line-height: 1.7; }

@media (max-width: 768px) {
  .video-item { grid-template-columns: 1fr; gap: 1.5rem; direction: ltr !important; }
}
</style>
